pipeline {
    agent any

    parameters {
        string(name: 'CLUSTER_NAME', description: 'Name of the CloudFormation stack to create')
        string(name: 'REGION', defaultValue: 'ap-south-1', description: 'AWS region to deploy the stack')
        string(name: 'CLUSTER_VERSION', defaultValue: '1.35', description: 'Enter The Cluster Version')
        string(name: 'SUBNET_IDS', description: 'Comma-separated list of subnet IDs for the node group')
        string(name: 'SECURITY_GROUP', description: 'Security Group ID for the EKS cluster')
        string(name: 'INSTANCE_TYPES', defaultValue: 'c6a.large', description: 'Instance types for the node group')
        choice(name: 'Action', choices: ['deploy', 'delete'], description: 'Choose the action to perform (deploy or delete)') 
    }

    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/yukesh-v/EKS-Karpenter.git'
            }
        }

        stage('pre-flight-check') {
            steps {
                sh "python3 pre-flight-check.py --region ${params.REGION} --cluster_name ${params.CLUSTER_NAME}" 
            }
        }

        stage('deploy-eks-cluster') {
            when {
                expression { params.Action == 'deploy' } 
            }
            steps {
                sh "python3 eks-creation.py --stack_name ${params.CLUSTER_NAME} --region ${params.REGION} --subnet-ids ${params.SUBNET_IDS} --security-group ${params.SECURITY_GROUP} --cluster_version ${params.CLUSTER_VERSION} --instance_types ${params.INSTANCE_TYPES}"
            }
        }

        stage('delete-eks-cluster') {
            when {
                expression { params.Action == 'delete' }
            }
            steps {
                sh "python3 eks-deletion.py --stack_name ${params.CLUSTER_NAME} --region ${params.REGION}"
            }
        }

        stage('Update kubeconfig') {
            when {
                expression { params.Action == 'deploy' }
            }
            steps {
                sh "aws eks update-kubeconfig --name ${params.CLUSTER_NAME} --region ${params.REGION}"
            }
        }

        stage('Install Karpenter') {
            when {
                expression { params.Action == 'deploy' }
            }
            steps {
                ansiblePlaybook playbook: "install-karpenter.yaml -vvv --extra-vars 'cluster_name=${params.CLUSTER_NAME} region=${params.REGION}'" 
            }
        }
    } 
    post {
        always {
            cleanWs()
        }
    }
}
